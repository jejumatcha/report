<script>
window.onload = function() {
  const d = new Date(), y = d.getFullYear(), m = d.getMonth()+1, day = d.getDate();
  document.getElementById('sign_date_display').innerHTML = y+' 년 &nbsp;&nbsp;&nbsp;&nbsp; '+m+' 월 &nbsp;&nbsp;&nbsp;&nbsp; '+day+' 일';
  document.getElementById('confirm_date_display').textContent = y+'년  '+m+'월  '+day+'일';
};
function sync() {
  document.getElementById('s_addr').textContent = document.getElementById('addr').value;
  document.getElementById('s_custno').textContent = document.getElementById('custno').value;
  document.getElementById('s_leak_loc').textContent = document.getElementById('leak_loc').value;
  document.getElementById('s_repair_date').textContent = document.getElementById('repair_date').value;
}
function syncName() {
  document.getElementById('s_custname').textContent = document.getElementById('applicant_name').value;
}
function setPhotoMode(mode) {
  const is4 = mode==='4';
  document.getElementById('photo4page').style.display = is4?'flex':'none';
  document.getElementById('photo2pages').style.display = is4?'none':'block';
  document.getElementById('btn-4').classList.toggle('active', is4);
  document.getElementById('btn-2').classList.toggle('active', !is4);
}
function triggerUpload(id) { document.getElementById(id).click(); }
['1','2','3','4'].forEach(function(n) {
  document.getElementById('inp'+n).addEventListener('change', function(e) { loadImg(e,'img'+n,'ph'+n); });
  document.getElementById('inp'+n+'b').addEventListener('change', function(e) { loadImg(e,'img'+n+'b','ph'+n+'b'); });
});
function loadImg(e, imgId, phId) {
  const file = e.target.files[0]; if (!file) return;
  const r = new FileReader();
  r.onload = function(ev) {
    const img = document.getElementById(imgId);
    img.src = ev.target.result; img.style.display = 'block';
    document.getElementById(phId).style.display = 'none';
  };
  r.readAsDataURL(file);
}

/* 도장 이미지 고정값 설정 방법:
   아래 STAMP_SRC 변수에 이미지 경로 또는 base64 데이터를 직접 입력하세요.
   예) const STAMP_SRC = "stamp.png";  (같은 폴더에 파일 위치)
       const STAMP_SRC = "data:image/png;base64,....";
   비워두면 도장 표시 안 됨. */
const STAMP_SRC = "data:image/png;base64,";

window.addEventListener('load', function() {
  if (STAMP_SRC) {
    const img = document.getElementById('stamp_img');
    img.src = STAMP_SRC;
    img.style.display = 'block';
  }
});
</script>
